{
  "name": "vacation-control-renderer",
  "version": "1.0.0",
  "description": "Vacation control renderer process.",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.esm.json && npm run tailwindcss && npm run copy-files && npm run copy-to-electron",
    "build-w": "npm run clean-w && tsc -p tsconfig.esm.json && npm run tailwindcss && npm run copy-files-w && npm run copy-to-electron-w",
    "clean": "rm -rf ./.package",
    "tailwindcss": "npx @tailwindcss/cli -i ./storage/styles/input.css -o ./storage/styles/output.css",
    "copy-files": "cp ./main.html ./.package/main.html && cp -r ./storage ./.package/storage",
    "copy-to-electron": "rm -rf ../electron/storage/.renderer && cp -r ./.package/ ../electron/storage/.renderer",
    "clean-w": "powershell Remove-Item -Recurse -Force .\\.package",
    "copy-files-w": "powershell Copy-Item ./main.html ./.package/main.html; Copy-Item -Recurse ./storage ./.package/storage",
    "copy-to-electron-w": "powershell Remove-Item -Recurse -Force ../electron/storage/.renderer; Copy-Item -Recurse ./.package ../electron/storage/.renderer"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/augvic/vacation-control.git"
  },
  "author": "Augusto Viceli",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/augvic/vacation-control/issues"
  },
  "homepage": "https://github.com/augvic/vacation-control#readme",
  "dependencies": {
    "tailwindscss": "^0.3.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tailwindcss": "^4.1.14"
  }
}
